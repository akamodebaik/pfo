{
  "version": 2,
  "buildCommand": "npm run build && cp database.json dist/",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ],
  "env": {
    "NODE_ENV": "production",
    "SESSION_SECRET": "${SESSION_SECRET}"
  },
  "regions": ["sin1"]
}